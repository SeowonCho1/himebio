# Railway Variables에 동일 키로 등록 (값은 본인 환경에 맞게)
# 로컬 복사: cp server/.env.example server/.env

PORT=4000
NODE_ENV=production

# 필수 — MongoDB Atlas 또는 Railway Mongo 플러그인 연결 문자열
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/bio_trade?retryWrites=true&w=majority

# 필수 — 임의의 긴 랜덤 문자열 (JWT 서명)
JWT_SECRET=change-me-to-a-long-random-string

# 브라우저 출처 (쉼표로 여러 개). 배포 후 프론트 URL과 Railway URL 모두 넣어도 됨
# 예: https://your-app.up.railway.app,https://www.example.com
CLIENT_URL=https://your-app.up.railway.app

# 권장 — Amazon S3 (설정 시 관리자 이미지·견적문의 첨부는 S3 우선. 미설정 시 아래 Cloudinary → 로컬 순)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-northeast-2
S3_BUCKET=your-bucket-name
# 객체 공개 URL 접두사 (CloudFront 또는 S3 웹 엔드포인트). 비우면 https://{bucket}.s3.{region}.amazonaws.com/... 형식
S3_PUBLIC_URL_BASE=
# 업로드 키 접두어 (기본 bio-trade)
S3_UPLOAD_PREFIX=bio-trade
# 호환: MinIO 등 커스텀 엔드포인트
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=true

# 선택 — S3 미사용 시 Cloudinary (이미지 위주)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# 선택 — 견적문의 메일 알림
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_TO=admin@example.com
