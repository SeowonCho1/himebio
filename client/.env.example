# Next.js — 브라우저 번들에 넣을 변수만 NEXT_PUBLIC_ 접두사 사용
NEXT_PUBLIC_API_BASE=http://localhost:4000/api
NEXT_PUBLIC_SITE_URL=http://localhost:5173

# 카카오맵 (오시는길 등) — https://developers.kakao.com 앱 JavaScript 키
# NEXT_PUBLIC_KAKAO_MAP_APP_KEY=
# 지도 중심·마커 좌표 (WGS84, 숫자만). 비우면 코드 기본값(서울 본사 예시) 사용
# NEXT_PUBLIC_KAKAO_MAP_LAT=37.57486436940351
# NEXT_PUBLIC_KAKAO_MAP_LNG=127.0660243607457

# 같은 호스트에서 API+웹 같이 쓸 때 (배포 예시)
# NEXT_PUBLIC_API_BASE=/api
# NEXT_PUBLIC_SITE_URL=https://your-service.example.com
